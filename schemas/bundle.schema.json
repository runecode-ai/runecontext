{
  "$schema": "http://json-schema.org/draft-7/schema#",
  "title": "Context Bundle Schema",
  "description": "Reusable context selector for RuneContext. Supports inheritance, aspect-aware includes/excludes. Schema version 1.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "includes"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Unknown versions must fail closed."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "description": "Unique bundle identifier. Lowercase alphanumeric with optional hyphens (not leading/trailing)."
    },
    "extends": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
      },
      "uniqueItems": true,
      "maxItems": 8,
      "description": "Parent bundle IDs. Depth-first, left-to-right linearization. Max depth 8."
    },
    "includes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "description": "Aspect-aware file/pattern inclusions.",
      "properties": {
        "project": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Include patterns under 'project/' aspect."
        },
        "standards": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Include patterns under 'standards/' aspect."
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Include patterns under 'specs/' aspect."
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Include patterns under 'decisions/' aspect."
        }
      }
    },
    "excludes": {
      "type": "object",
      "additionalProperties": false,
      "description": "Aspect-aware file/pattern exclusions. Applied after includes.",
      "properties": {
        "project": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Exclude patterns under 'project/' aspect."
        },
        "standards": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Exclude patterns under 'standards/' aspect."
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Exclude patterns under 'specs/' aspect."
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Exclude patterns under 'decisions/' aspect."
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Optional extensions. Allowed only when runecontext.yaml sets allow_extensions: true. Non-authoritative; cannot affect bundle semantics.",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null",
          "array",
          "object"
        ]
      },
      "propertyNames": {
        "pattern": "^[a-z0-9]([a-z0-9.-]*[a-z0-9])?$",
        "description": "Extension keys must be namespaced (e.g., 'dev.acme.custom', 'io.runecode.metadata')."
      }
    }
  }
}
