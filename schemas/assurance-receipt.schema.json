{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "kind", "subject_id", "created_at", "canonicalization", "receipt_id", "receipt_hash"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "receipt"},
    "subject_id": {"type": "string"},
    "created_at": {"type": "integer"},
    "canonicalization": {"const": "runecontext-canonical-json-v1"},
    "value": {},
    "receipt_id": {"type": "string"},
    "receipt_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "provenance": {"type": "string"}
  },
  "additionalProperties": false
}
